{
	"name": "@ungate/api",
	"type": "module",
	"scripts": {
		"start": "DB_PATH=$HOME/.ungate/data-dev.db PORT=4783 node -r source-map-support/register dist/main.js",
		"build": "pnpm run clean && tsc -p tsconfig.build.json && pnpm run build:postbuild",
		"build:watch": "pnpm run clean && tsc-watch -p tsconfig.build.json --onCompilationComplete \"pnpm run build:postbuild\"",
		"build:postbuild": "tsc-alias -p tsconfig.build.json --resolve-full-paths",
		"build:bundle": "tsup",
		"clean": "rm -rf dist",
		"lint": "eslint src/",
		"lint:fix": "eslint src/ --fix",
		"test": "pnpm run test:unit && pnpm run test:integration",
		"test:unit": "vitest run --config tests/unit/vitest.config.ts",
		"test:integration": "vitest run --config tests/integration/vitest.config.ts",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate"
	},
	"dependencies": {
		"@agentclientprotocol/sdk": "^0.15.0",
		"@fastify/cors": "~11.2.0",
		"@ungate/shared": "workspace:*",
		"better-sqlite3": "12.9.0",
		"date-fns": "~4.1.0",
		"drizzle-orm": "~0.43.1",
		"fastify": "~5.8.5",
		"lodash-es": "~4.18.1",
		"source-map-support": "~0.5.21",
		"tslib": "~2.8.1",
		"zod": "~4.3.6"
	},
	"devDependencies": {
		"@types/better-sqlite3": "~7.6.13",
		"@types/lodash-es": "~4.17.12",
		"@types/node": "~22.15.35",
		"@ungate/dev-kit": "workspace:*",
		"@vitest/coverage-v8": "~4.0.18",
		"drizzle-kit": "~0.31.10",
		"esbuild": "~0.27.4",
		"tsc-alias": "~1.8.16",
		"tsc-watch": "~6.2.1",
		"tsup": "~8.5.1",
		"typescript": "~5.7.0",
		"vite": "~8.0.0",
		"vite-tsconfig-paths": "~5.1.4",
		"vitest": "~4.0.18"
	}
}
