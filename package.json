{
	"name": "@ungate/root",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@10.33.1",
	"engines": {
		"node": ">=22 <23",
		"pnpm": ">=10.0.0"
	},
	"scripts": {
		"tunnel": "pnpm --filter @ungate/scripts run tunnel",
		"package:build": "bash scripts/build-package/run.sh",
		"lint:fix": "pnpm -r --parallel run lint:fix",
		"test": "pnpm --filter ungate test && pnpm --filter @ungate/api test",
		"prepare": "husky"
	},
	"devDependencies": {
		"@ungate/dev-kit": "workspace:*",
		"eslint": "~9.39.4",
		"husky": "~9.1.7"
	}
}
